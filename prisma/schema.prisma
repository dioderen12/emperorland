// Discord Staking Game - Prisma schema
// SQLite file-based DB for MVP. Easy to swap to Postgres later.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// A player. Identified by Discord ID once OAuth completes; a "demo" placeholder
// user (no discordId, username="demo") exists for unauthenticated local dev.
model User {
  id            String    @id @default(cuid())
  discordId     String?   @unique
  // App-displayed identifier. Default empty so NextAuth's PrismaAdapter can
  // create User rows without populating it; `events.createUser` in src/auth.ts
  // copies the Discord name into here right after the adapter's create.
  username      String    @default("")
  // NextAuth standard field. PrismaAdapter writes the Discord username here
  // directly during user creation. We mirror it to `username` for our own code.
  name          String?
  points        Int       @default(0)
  createdAt     DateTime  @default(now())

  // Discord role-gating. Re-evaluated on every sign-in from the member's roles
  // in the configured guild (see src/lib/access.ts). hasAccess gates all
  // gameplay; discordRoles is the cached CSV of role ids for debugging.
  hasAccess       Boolean   @default(false)
  discordRoles    String?
  accessCheckedAt DateTime?

  // NextAuth standard fields
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  // Community boss raid: cooldown gate between attacks.
  lastBossAttackAt DateTime?

  ownedAnimals  OwnedAnimal[]
  packOpenings  PackOpening[]
  transactions  Transaction[]
  dungeonEvents DungeonEvent[]
  bossAttacks   BossAttack[]
  challengerMatches Match[] @relation("challenger")
  opponentMatches   Match[] @relation("opponent")
  accounts      Account[]
  sessions      Session[]
}

// A PvP 3v3 betting match. Both sides escrow `wager` points; the auto-battle is
// resolved server-side into a playback log; winner takes the 2× pot. See
// src/lib/pvp.ts.
model Match {
  id             String    @id @default(cuid())
  status         String    @default("open") // open | resolved | declined | cancelled
  wager          Int
  directed       Boolean   @default(false)  // true = challenge aimed at a specific user
  challengerId   String
  opponentId     String?                    // null = open lobby; set at create (directed) or accept
  challengerTeam String                     // JSON snapshot of the 3 fighters
  opponentTeam   String?                    // JSON snapshot (set on accept)
  winnerId       String?
  logJson        String?                    // battle playback (teams + ordered events)
  // false once a match resolves until the challenger has watched it — drives the
  // "Battle ready!" notification + auto-play (the challenger wasn't present at
  // accept time, so they shouldn't have to dig it out of history).
  challengerSeen Boolean   @default(true)
  createdAt      DateTime  @default(now())
  resolvedAt     DateTime?

  challenger User  @relation("challenger", fields: [challengerId], references: [id], onDelete: Cascade)
  opponent   User? @relation("opponent", fields: [opponentId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([opponentId, status])
  @@index([challengerId, status])
}

// A server-wide raid boss with a shared HP pool. One is active at a time; when
// HP hits 0 it's defeated and rewards are paid to everyone who dealt damage.
// Spawned lazily (no cron) — see src/lib/boss.ts.
model Boss {
  id         String       @id @default(cuid())
  name       String
  spriteUrl  String
  element    String       // type code the boss IS, for attacker effectiveness
  maxHp      Int
  currentHp  Int
  status     String       @default("active") // active | defeated
  spawnedAt  DateTime     @default(now())
  endsAt     DateTime
  defeatedAt DateTime?
  attacks    BossAttack[]

  @@index([status])
}

// One logged hit against a boss. Sum per user = that user's contribution and
// leaderboard rank for the boss.
model BossAttack {
  id        String   @id @default(cuid())
  bossId    String
  userId    String
  damage    Int
  crit      Boolean  @default(false)
  createdAt DateTime @default(now())

  boss Boss @relation(fields: [bossId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([bossId, userId])
  @@index([userId])
}

// NextAuth/Auth.js standard tables — managed by the adapter, no manual writes.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  sessionToken String   @id
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// The catalog of animals that can drop from packs. Seeded, not user-created.
model AnimalSpecies {
  id              String  @id @default(cuid())
  name            String  @unique
  rarity          String  // common | uncommon | rare | epic | legendary
  spriteUrl       String  // remote image URL (PokéAPI official artwork)
  packWeight      Int     // weighted-roll value within its rarity tier
  stakeRatePerHour Int    // points earned per hour while staked
  power           Int     @default(0)     // PWR stat shown on the card
  typeCode        String  @default("NOR") // 3-letter type code: FIR/WTR/GRS/ELC/etc.

  owned           OwnedAnimal[]
}

// An animal instance owned by a user. One species can be owned multiple times (duplicates).
model OwnedAnimal {
  id              String        @id @default(cuid())
  userId          String
  speciesId       String
  obtainedAt      DateTime      @default(now())

  // Dungeon deployment state.
  // dungeonId is the source of truth: null = in party, otherwise "grasslands"/"cave"/"volcano".
  // isStaked kept as a derived convenience flag for legacy queries (always equals dungeonId != null).
  isStaked        Boolean       @default(false)
  dungeonId       String?
  stakedAt        DateTime?     // when current deployment began
  unclaimedPoints Int           @default(0) // banked from continuous earning + event drops

  // Idle exploration state.
  lastEventAt     DateTime?     // last tick when an RNG event was resolved for this animal
  cooldownUntil   DateTime?     // exploration paused until this time (mob/boss loss penalty)

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  species         AnimalSpecies @relation(fields: [speciesId], references: [id])
  events          DungeonEvent[]

  @@index([userId])
}

// One row per RNG event that fires for a deployed Pokemon. Drives the event log
// and lets us audit drop rates across the player base later.
model DungeonEvent {
  id            String      @id @default(cuid())
  userId        String
  ownedAnimalId String
  dungeonId     String
  kind          String      // treasure | mob_win | mob_loss | rare_drop | boss_win | boss_loss
  pointsDelta   Int         // signed reward (loss events = 0; cooldown is the penalty)
  cooldownMs    Int         @default(0)
  description   String      // human-readable for the event log
  occurredAt    DateTime    @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  ownedAnimal OwnedAnimal @relation(fields: [ownedAnimalId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt])
  @@index([ownedAnimalId])
}

// Audit log for pack openings (useful for analytics / debugging odds).
model PackOpening {
  id          String   @id @default(cuid())
  userId      String
  cost        Int
  resultJson  String   // JSON array of species ids obtained, e.g. ["id1","id2","id3"]
  openedAt    DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Audit log for any point movement (purchase, stake claim, admin adjust).
model Transaction {
  id        String   @id @default(cuid())
  userId    String
  kind      String   // pack_purchase | stake_claim | admin_adjust
  delta     Int      // signed change in points
  reason    String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
